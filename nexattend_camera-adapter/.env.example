PORT=5100
LOG_LEVEL=info
CAMERA_ID=front-gate
CAMERA_NAME=Front Gate Camera
CAMERA_LOCATION=Main Entrance
CAMERA_POLL_ENABLED=false
CAMERA_POLL_INTERVAL_MS=5000

# Optional HTTP recognizer endpoint. It should return either:
# { "studentId": "...", "confidence": 0.94 } or { "matches": [{ "studentId": "...", "confidence": 0.94 }] }
FACE_RECOGNITION_URL=
FACE_RECOGNITION_TIMEOUT_MS=5000
FACE_RECOGNITION_MIN_CONFIDENCE=0.75

BACKEND_BASE_URL=http://localhost:4000
BACKEND_STUDENTS_PATH=/api/v1/users
BACKEND_API_TOKEN=
ENROLLMENT_REFRESH_INTERVAL_MS=300000
FACE_MATCH_ENABLED=true
FACE_MATCH_MIN_SIMILARITY=0.82

# MongoDB is required for face embedding storage.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=nexattend_face_intelligence
FACE_MONGODB_URI=
FACE_MONGODB_DATABASE=nexattend_face_intelligence
FACE_EMBEDDING_COLLECTION=face_embeddings
FACE_EMBEDDING_MIN_SIMILARITY=0.82

FACE_DETECTION_ENABLED=true
FACE_DETECTION_MIN_PROBABILITY=0.85
FACE_DETECTION_MAX_FACES=5

CAMERA_SYNC_PUBLISH_ENABLED=true
AMQP_URL=
CLOUDAMQP_URL=
CAMERA_SYNC_EXCHANGE=nexattend.camera-sync
CAMERA_SYNC_RECOGNITION_ROUTING_KEY=face.matched
AMQP_RECONNECT_DELAY_MS=5000
