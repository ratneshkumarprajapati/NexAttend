NODE_ENV=development
APP_NAME=NexAttend
PORT=4000
WS_PORT=4000

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexattend?schema=public

JWT_SECRET=replace-with-a-long-random-secret
HASH_SALT=10
HASH_SECRET=replace-with-a-long-random-hash-secret

ROUTER_EXECUTION_MODE=router-adapter
ROUTER_SYNC_MODE=polling
ROUTER_ADAPTER_BASE_URL=http://localhost:5000
ROUTER_POLL_INTERVAL=15000

AMQP_URL=
CLOUDAMQP_URL=
ROUTER_SYNC_EXCHANGE=nexattend.router-sync
ROUTER_SYNC_SNAPSHOT_ROUTING_KEY=router.snapshot
ROUTER_SYNC_SNAPSHOT_QUEUE=nexattend.router-snapshots
AMQP_RECONNECT_DELAY_MS=5000
AMQP_PREFETCH=1

CAMERA_QUEUE_ENABLED=false
CAMERA_SYNC_EXCHANGE=nexattend.camera-sync
CAMERA_SYNC_RECOGNITION_ROUTING_KEY=face.matched
CAMERA_SYNC_RECOGNITION_QUEUE=nexattend.camera-recognitions
CAMERA_MIN_CONFIDENCE=0.75

MOBILE_QUEUE_ENABLED=false
MOBILE_SYNC_EXCHANGE=nexattend.mobile-sync
MOBILE_SYNC_EVENT_ROUTING_KEY=mobile.device-event
MOBILE_SYNC_EVENT_QUEUE=nexattend.mobile-events

ROUTER_KEY=default
ROUTER_NAME=Default Router
ROUTER_PROVIDER=generic
ROUTER_BASE_URL=https://192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=admin
ROUTER_LOGIN_API_URL=/dm/sys/?cmd=Login
ROUTER_CONNECTED_DEVICES_API_URL=/dm/tr98/?objs=WLANAssociatedDevice&page=StatusPage-CurrentWirelessUser
ROUTER_LOGIN_STATUS_CODE_PATH=Login.status_code
ROUTER_LOGIN_STATUS_PATH=Login.data.login.status
ROUTER_LOGIN_SUCCESS_STATUS=success
ROUTER_LOGIN_TOKEN_PATH=Login.data.login.authenticatedToken
ROUTER_CONNECTED_DEVICES_DATA_PATH=WLANAssociatedDevice.data
ROUTER_PRIORITY=100
ROUTER_ENABLED=true

MIN_SESSION_DURATION=120
MAX_INACTIVE_TIME=300
RSSI_THRESHOLD=-80

LOG_DUMP_ENABLED=true
LOG_DUMP_RUN_ON_STARTUP=true
LOG_DUMP_CLEAN_AFTER_DUMP=true
LOG_DUMP_DIRECTORY=exports/log-dumps
LOG_DUMP_HOUR=23
LOG_DUMP_MINUTE=0
LOG_DUMP_BATCH_SIZE=5000

SYSTEM_LOG_ENABLED=true
SYSTEM_LOG_DIRECTORY=clogs
SYSTEM_LOG_RETENTION_DAYS=3

OTEL_ENABLED=false
OTEL_EXPORTER=console
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics
OTEL_METRICS_ENABLED=false
OTEL_METRIC_EXPORT_INTERVAL_MS=15000
