            },
            "description": "Update one or more profile fields."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Device APIs",
      "description": "Authenticated device endpoints mounted at `/api/v1/devices`. These use the logged-in user's token to resolve `userId`.",
      "item": [
        {
          "name": "Register Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response?.data?.id) pm.collectionVariables.set('deviceId', String(response.data.id));",
                  "if (response?.data?.publicId) pm.collectionVariables.set('devicePublicId', response.data.publicId);",
                  "if (response?.data?.hashedMac) pm.collectionVariables.set('lastDeviceHash', response.data.hashedMac);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"deviceName\": \"Ratnesh Laptop\",\n  \"macAddress\": \"{{macAddress}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{devicePath}}/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{devicePath}}",
                "register"
              ]
            },
            "description": "Register the authenticated user's device. The backend hashes `macAddress` before storing it."
          },
          "response": []
        },
        {
          "name": "Get My Devices",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{devicePath}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{devicePath}}"
              ]
            },
            "description": "Fetch devices for the authenticated user."
          },
          "response": []
        }
      ]
    }
  ]
