{
  "info": {
    "_postman_id": "7d96ec51-2b2a-46b8-8af1-8f4dc792d0d1",
    "name": "NexAttend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for NexAttend versioned APIs. Run Auth Flow first to capture token and IDs for users, profiles, and devices."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "apiBasePath",
      "value": "api/v1"
    },
    {
      "key": "authPath",
      "value": "auth"
    },
    {
      "key": "userPath",
      "value": "users"
    },
    {
      "key": "profilePath",
      "value": "profiles"
    },
    {
      "key": "devicePath",
      "value": "devices"
    },
    {
      "key": "authToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "userPublicId",
      "value": "replace-with-user-public-id"
    },
    {
      "key": "deviceId",
      "value": "1"
    },
    {
      "key": "devicePublicId",
      "value": "replace-with-device-public-id"
    },
    {
      "key": "macAddress",
      "value": "AA:BB:CC:DD:EE:01"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{authToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth Flow",
      "description": "Run Register User or Login User first. Successful responses store `authToken`, `userId`, and `userPublicId` for later requests.",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response?.data?.token) pm.collectionVariables.set('authToken', response.data.token);",
                  "if (response?.data?.user?.id) pm.collectionVariables.set('userId', String(response.data.user.id));",
                  "if (response?.data?.user?.publicId) pm.collectionVariables.set('userPublicId', response.data.user.publicId);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"STUDENT\",\n  \"firstName\": \"Ratnesh\",\n  \"lastName\": \"Kumar\",\n  \"phoneNo\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{authPath}}/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{authPath}}",
                "register"
              ]
            },
            "description": "Create a user through the auth flow and capture token + IDs."
          },
          "response": []
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "if (response?.data?.token) pm.collectionVariables.set('authToken', response.data.token);",
                  "if (response?.data?.user?.id) pm.collectionVariables.set('userId', String(response.data.user.id));",
                  "if (response?.data?.user?.publicId) pm.collectionVariables.set('userPublicId', response.data.user.publicId);"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student1@example.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{authPath}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{authPath}}",
                "login"
              ]
            },
            "description": "Login with existing credentials and refresh the stored token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User APIs",
      "description": "Versioned user endpoints mounted at `/api/v1/users`.",
      "item": [
