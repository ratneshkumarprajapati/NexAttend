                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated.student1@example.com\",\n  \"role\": \"ADMIN\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{userPath}}/{{userPublicId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{userPath}}",
                "{{userPublicId}}"
              ]
            },
            "description": "Update one or more user fields."
          },
          "response": []
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{userPath}}/{{userPublicId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{userPath}}",
                "{{userPublicId}}"
              ]
            },
            "description": "Soft delete a user by publicId."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Profile APIs",
      "description": "Profiles are mounted at `/api/v1/profiles` and use numeric `userId` in the current routes.",
      "item": [
        {
          "name": "Create Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"firstName\": \"Ratnesh\",\n  \"lastName\": \"Kumar\",\n  \"phoneNo\": \"9876543210\",\n  \"department\": \"CSE\",\n  \"enrolmentNo\": \"NA2026001\",\n  \"year\": 4,\n  \"preprationGoal\": {\n    \"target\": \"95_percent_attendance\",\n    \"focus\": \"placement_preparation\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{profilePath}}/create",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{profilePath}}",
                "create"
              ]
            },
            "description": "Create a profile for a user using numeric userId."
          },
          "response": []
        },
        {
          "name": "Get Profile By UserId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{profilePath}}/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
                "{{profilePath}}",
                "{{userId}}"
              ]
            },
            "description": "Fetch a profile by numeric userId."
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"department\": \"ECE\",\n  \"year\": 3,\n  \"preprationGoal\": {\n    \"target\": \"internship\",\n    \"focus\": \"system_design\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiBasePath}}/{{profilePath}}/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiBasePath}}",
