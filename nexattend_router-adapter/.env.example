PORT=5000
LOG_LEVEL=info
ROUTER_POLL_INTERVAL_MS=5000

ROUTER_SYNC_PUBLISH_ENABLED=false
AMQP_URL=
CLOUDAMQP_URL=
ROUTER_SYNC_EXCHANGE=nexattend.router-sync
ROUTER_SYNC_SNAPSHOT_ROUTING_KEY=router.snapshot
AMQP_RECONNECT_DELAY_MS=5000

ROUTER_KEY=default
ROUTER_NAME=Default Router
ROUTER_PROVIDER=generic
ROUTER_BASE_URL=https://192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=admin
ROUTER_LOGIN_API_URL=/dm/sys/?cmd=Login
ROUTER_CONNECTED_DEVICES_API_URL=/dm/tr98/?objs=WLANAssociatedDevice&page=StatusPage-CurrentWirelessUser
ROUTER_LOGIN_STATUS_CODE_PATH=Login.status_code
ROUTER_LOGIN_STATUS_PATH=Login.data.login.status
ROUTER_LOGIN_SUCCESS_STATUS=success
ROUTER_LOGIN_TOKEN_PATH=Login.data.login.authenticatedToken
ROUTER_CONNECTED_DEVICES_DATA_PATH=WLANAssociatedDevice.data
ROUTER_FIELD_MAC=associatedDeviceMACAddress
ROUTER_FIELD_IP=associatedDeviceIPAddress
ROUTER_FIELD_HOSTNAME=associatedDeviceHostName
ROUTER_FIELD_MANUFACTURER=associatedDeviceManufacturer
ROUTER_FIELD_BAND=associatedDeviceStandard
ROUTER_FIELD_RSSI=associatedDeviceRSSI
ROUTER_FIELD_TX_RATE=associatedDeviceTxRate
ROUTER_FIELD_RX_RATE=associatedDeviceRecvRate
ROUTER_FIELD_DURATION=associatedDeviceDuration
ROUTER_FIELD_EXPIRE_TIME=associatedDeviceExpireTime
ROUTER_FIELD_SSID_INDEX=associatedDeviceSSIDIndex
ROUTER_FIELD_IID=iid
ROUTER_TIMEOUT_MS=5000
ROUTER_RETRY_ATTEMPTS=2
ROUTER_RETRY_DELAY_MS=300
ROUTER_TOKEN_TTL_MS=300000
ROUTER_PRIORITY=100
ROUTER_ENABLED=true

# Advanced: use ROUTERS_JSON instead of the single-router variables above.
# ROUTERS_JSON=[{"type":"API","key":"main","name":"Main Router","enabled":true,"baseUrl":"http://192.168.1.1","username":"admin","password":"admin","loginApiUrl":"/dm/sys/?cmd=Login","connectedDevicesApiUrl":"/dm/tr98/?objs=WLANAssociatedDevice&page=StatusPage-CurrentWirelessUser","loginStatusCodePath":"Login.status_code","loginStatusPath":"Login.data.login.status","loginSuccessStatus":"success","loginTokenPath":"Login.data.login.authenticatedToken","connectedDevicesDataPath":"WLANAssociatedDevice.data","deviceFieldMap":{"mac":"associatedDeviceMACAddress","ip":"associatedDeviceIPAddress","hostname":"associatedDeviceHostName","manufacturer":"associatedDeviceManufacturer","band":"associatedDeviceStandard","rssi":"associatedDeviceRSSI","txRate":"associatedDeviceTxRate","rxRate":"associatedDeviceRecvRate","duration":"associatedDeviceDuration","expireTime":"associatedDeviceExpireTime","ssidIndex":"associatedDeviceSSIDIndex","iid":"iid"}}]
