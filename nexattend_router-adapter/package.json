{
  "name": "router-microservice",
  "version": "1.0.0",
  "description": "Production-grade router adapter microservice with API and Playwright scraper integrations.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "npm run build && node dist/server.js",
    "debug": "npm run build && node --inspect dist/bootstrap.js",
    "debug:brk": "npm run build && node --inspect-brk dist/bootstrap.js",
    "watch": "tsc --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "express": "^4.19.2",
    "playwright": "^1.46.1",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
