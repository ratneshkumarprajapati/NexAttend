{
  "name": "nexattend-mobile-adapter",
  "version": "1.0.0",
  "description": "Mobile adapter microservice for receiving app device events and publishing aggregated attendance events.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "npm run build && node dist/server.js",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "amqplib": "^1.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
